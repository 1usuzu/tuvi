# =========================
# Backend API + Worker (required)
# =========================

# Postgres/Neon connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Backend
PORT=3000
# Comma-separated list; example: http://localhost:8080,https://your-domain.com
CORS_ORIGIN=http://localhost:8080

# Gmail (use App Password)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
# Optional override (must be a single env value)
EMAIL_FROM="Thuận Thời Hiếu Mệnh <your_gmail@gmail.com>"

# Google Drive upload target folder id (used by googleDriveService.js)
GOOGLE_DRIVE_FOLDER_ID=

# Mount service-account JSON and point to it (DO NOT COMMIT the JSON)
# Example in docker-compose:
#   - ./secrets/service-account.json:/run/secrets/google-service-account.json:ro
GOOGLE_SERVICE_ACCOUNT_PATH=/run/secrets/google-service-account.json

# Worker (Playwright)
PLAYWRIGHT_HEADLESS=true
# Leave empty in container (prefer bundled Chromium). For local dev you can set: chrome
PLAYWRIGHT_CHANNEL=


# =========================
# Frontend (dev only - Vite)
# =========================
# In Docker (nginx reverse proxy), you can omit this (defaults to '').
# For non-docker local dev: point to backend
VITE_API_BASE_URL=http://localhost:3000

